{%- liquid
  assign fix_ratio = false
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign video_alt = section.settings.video.alt | default: section.settings.heading
  assign alt = video_alt | escape
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image
  assign has_video = false
  if section.settings.video != blank or section.settings.video_url != blank or section.settings.video_mp4 != blank
    assign has_video = true
  endif
  if section.settings.video_mp4 != blank and section.settings.video == blank and section.settings.video_url == blank
    assign video_id = section.id | append: '-mp4'
  endif
  if section.settings.video != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet">
{{ 'precision-pdp-design-tokens.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'section-precision-product-mechanics.css' | asset_url | stylesheet_tag }}

{%- capture sizes -%}
  (min-width: 990px) 50vw, 100vw
{%- endcapture -%}

<div class="precision-mechanics section-{{ section.id }}-padding">
  <div class="precision-mechanics__inner page-width">
    <div class="precision-mechanics__media">
      <div class="precision-mechanics__video-wrap" data-precision-mechanics-video{% unless has_video %} data-no-video{% endunless %}>
        {%- unless has_video -%}
          <div class="precision-mechanics__poster precision-mechanics__poster--static">
            {%- if poster != null -%}
              {{ poster | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: sizes, widths: '400, 800, 1200, 2000', alt: alt }}
            {%- else -%}
              {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
          </div>
        {%- else -%}
        <noscript>
          <div class="precision-mechanics__video-fallback">
            {%- if section.settings.video != blank -%}
              {{ section.settings.video | video_tag: image_size: '1100x', loop: section.settings.enable_video_looping, controls: true, muted: false }}
            {%- elsif section.settings.video_url != blank -%}
              <a href="{{ section.settings.video_url }}">{{ poster | image_url: width: 1500 | image_tag: loading: 'lazy', alt: alt }}</a>
            {%- elsif section.settings.video_mp4 != blank -%}
              <video controls playsinline preload="metadata"{% if poster != null %} poster="{{ poster | image_url: width: 2000 }}"{% endif %}>
                <source src="{{ section.settings.video_mp4 }}" type="video/mp4">
              </video>
            {%- endif -%}
          </div>
        </noscript>
        <deferred-media
          class="precision-mechanics__deferred deferred-media no-js-hidden media-wrapper{% if fix_ratio %} media-fit-cover{% endif %}"
          data-media-id="{{ video_id }}"
          {% if poster != null %}
            style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <button
            id="Deferred-Poster-{{ section.id }}"
            class="precision-mechanics__poster media deferred-media__poster"
            type="button"
            aria-label="{{ 'sections.video.load_video' | t: description: alt }}"
          >
            {%- if poster != null -%}
              {{ poster
                | image_url: width: 2000
                | image_tag: loading: 'lazy', sizes: sizes, widths: '400, 800, 1200, 2000', alt: alt
              }}
            {%- else -%}
              {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
            <span class="precision-mechanics__poster-inner">
              <span class="precision-mechanics__play-fab" aria-hidden="true">
                <span class="material-symbols-outlined">play_arrow</span>
              </span>
            </span>
          </button>
          <template>
            {%- if section.settings.video != blank -%}
              {{ section.settings.video | video_tag:
                image_size: '1100x',
                autoplay: true,
                loop: section.settings.enable_video_looping,
                controls: true,
                muted: false
              }}
            {%- elsif section.settings.video_url != blank -%}
              <video-section
                data-init-mode="template"
                data-parent="deferred-media"
                data-loop="{% if section.settings.enable_video_looping %}1{% else %}0{% endif %}"
                data-type="{{ section.settings.video_url.type }}"
                data-video-id="{{ section.settings.video_url.id }}"
              ></video-section>
            {%- elsif section.settings.video_mp4 != blank -%}
              <video
                class="precision-mechanics__html5-video"
                playsinline
                controls
                preload="metadata"
                autoplay
                {% if section.settings.enable_video_looping %}loop{% endif %}
                {% if poster != null %}poster="{{ poster | image_url: width: 2000 }}"{% endif %}
              >
                <source src="{{ section.settings.video_mp4 }}" type="video/mp4">
              </video>
            {%- endif -%}
          </template>
        </deferred-media>
        {%- endunless -%}
      </div>
    </div>

    <div class="precision-mechanics__content">
      {%- if section.settings.subheading != blank -%}
        <p class="precision-mechanics__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="precision-mechanics__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="precision-mechanics__body rte">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="precision-mechanics__list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'bullet' -%}
                <li {{ block.shopify_attributes }}>
                  <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                  <span>{{ block.settings.text | escape }}</span>
                </li>
            {%- endcase -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

<script src="{{ 'section-precision-product-mechanics.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: #ffffff;
    color: #000000;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Precision mechanics",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Feature bullet",
          "label": "Text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video",
      "info": "Optional. If set, this is used first (before YouTube/Vimeo and MP4)."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "External video URL",
      "accept": ["youtube", "vimeo"],
      "info": "YouTube or Vimeo. Ignored if Shopify video or MP4 URL is set."
    },
    {
      "type": "url",
      "id": "video_mp4",
      "label": "MP4 video URL",
      "info": "Upload an .mp4 in Settings → Content → Files, copy the link, and paste it here. Used when Shopify video and YouTube/Vimeo are empty."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image",
      "info": "Poster before play (recommended for MP4 and external video)."
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": false,
      "label": "Loop video"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Engineering",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Internal Mechanics.",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "default": "<p>The Tracki Pro isn't just a shell. Inside sits a custom-engineered ceramic antenna and a proprietary ultra-low power chipset designed for maximum signal penetration in urban canyons.</p>",
      "label": "Body"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Precision mechanics",
      "blocks": [
        {
          "type": "bullet",
          "settings": {
            "text": "Enhanced GPS/A-GPS/GLONASS hybrid positioning"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "Integrated Wi-Fi tracking for indoor precision"
          }
        }
      ]
    }
  ]
}
{% endschema %}
