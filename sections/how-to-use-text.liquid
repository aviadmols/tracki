<style>
    .how-guide {
  background: #26282a;
  {% comment %} padding: 70px 0; {% endcomment %}
  color: #ffffff;
}

.how-guide__wrapper {
  max-width: 900px;
  margin: 0 auto;
}

.how-guide__item {
  margin-bottom: 60px;
}

.how-guide__heading {
    color: #FFF;
    text-align: center;
    font-size: 30px;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
}

.how-guide__text {
    color: #FAFAFA;
    text-align: justify;
    font-size: 16px;
    font-style: normal;
    font-weight: 450;
    line-height: normal;
}

.how-guide__text p {
  margin-bottom: 15px;
}

/* Mobile */
/* ===== Large Desktop ===== */
@media (min-width: 1400px) {
  .how-guide__wrapper {
    max-width: 1100px;
  }

  .how-guide__heading {
    font-size: 34px;
  }

  .how-guide__text {
    font-size: 17px;
    line-height: 1.8;
  }
}

/* ===== Laptop ===== */
@media (max-width: 1200px) {
  .how-guide__wrapper {
    max-width: 850px;
  }
}

/* ===== Tablet ===== */
@media (max-width: 992px) {
  .how-guide {
    padding: 60px 30px;
  }

  .how-guide__wrapper {
    max-width: 700px;
  }

  .how-guide__heading {
    font-size: 26px;
    margin-bottom: 20px;
  }

  .how-guide__text {
    font-size: 15px;
    line-height: 1.7;
  }

  .how-guide__item {
    margin-bottom: 40px;
  }
}

/* ===== Mobile ===== */
@media (max-width: 768px) {
  {% comment %} .how-guide {
    padding: 50px 20px;
  } {% endcomment %}

  .how-guide__heading {
    font-size: 22px;
    line-height: 1.4;
  }

  .how-guide__text {
    font-size: 14px;
    line-height: 1.7;
    text-align: left; /* better readability on mobile */
  }

  .how-guide__item {
    margin-bottom: 35px;
  }
}

/* ===== Small Mobile ===== */
@media (max-width: 480px) {
  .how-guide {
    padding: 40px 15px;
  }

  .how-guide__heading {
    font-size: 20px;
  }

  .how-guide__text {
    font-size: 13.5px;
    line-height: 1.6;
  }
}
</style>
<section class="how-guide">
  <div class="page-width how-guide__wrapper">

    {% for block in section.blocks %}
      <div class="how-guide__item divider-sec" {{ block.shopify_attributes }}>

        {% if block.settings.heading != blank %}
          <h2 class="how-guide__heading">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="how-guide__text">
            {{ block.settings.text }}
          </div>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "How TO Use Text",
  "blocks": [
    {
      "type": "content",
      "name": "Heading + Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "A comprehensive guide \"How GPS Tracker Works\""
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Have you ever wondered where your car is? How safe your teen driver is? Or if your pets decided to explore the neighbourhoods?</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How TO Use Text",
      "blocks": [
        { "type": "content" }
      ]
    }
  ]
}
{% endschema %}