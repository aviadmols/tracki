{%- liquid
  assign product_form_id = 'product-form-precision-' | append: section.id
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign hero_media = product.selected_or_first_available_variant.featured_media
  if hero_media == blank
    assign hero_media = product.featured_media
  endif
  if product.media.size > 0
    assign first_image = product.media.first
    if product.selected_or_first_available_variant.featured_media != null and section.settings.show_featured_media == false
      assign first_image = product.selected_or_first_available_variant.featured_media
    endif
    assign first_image_ratio = 1 | divided_by: first_image.aspect_ratio | times: 100
  endif
-%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet">

{{ 'precision-pdp-design-tokens.css' | asset_url | stylesheet_tag }}
{{ 'section-precision-product-hero.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{%- if product.media.size > 0 -%}
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
  <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
{%- if product.quantity_price_breaks_configured? -%}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- if product.quantity_price_breaks_configured? -%}
  <script src="{{ 'vp-show-more.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
<script src="{{ 'section-precision-product-hero.js' | asset_url }}" defer="defer"></script>

<product-info
  id="MainProduct-{{ section.id }}"
  class="precision-pdp-hero section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  {% if collection and collection.handle %}
    data-url="{{ product.url | within: collection }}"
  {% else %}
    data-url="{{ product.url }}"
  {% endif %}
>
  <div class="precision-pdp-hero__inner page-width">
    <div class="precision-pdp-hero__media">
      {%- if product.media.size > 0 -%}
        <div
          class="precision-pdp-gallery product product--large product--left product--thumbnail_slider flex-grid flex-grid--1-col{% if section.settings.gallery_image_ratio == 'adapt' %} product--adapt{% endif %}{% if section.settings.gallery_mobile_image_ratio == 'adapt' %} product--mobile-adapt{% endif %}{% unless section.settings.enable_image_zoom %} product--zoom-disabled{% endunless %}"
        >
          <div class="flex-grid__item product__media-wrapper">
            {% render 'precision-product-gallery', precision_pdp: true %}
          </div>
        </div>
      {%- else -%}
        <div class="precision-pdp-hero__media-inner" data-precision-hero-media>
          {%- if hero_media != blank -%}
            {%- if hero_media.media_type == 'video' -%}
              {{ hero_media | video_tag: image_size: '1100x', autoplay: false, loop: true, muted: true, controls: false }}
            {%- else -%}
              <img
                src="{{ hero_media | image_url: width: 1500 }}"
                alt="{{ hero_media.alt | default: product.title | escape }}"
                width="{{ hero_media.width }}"
                height="{{ hero_media.height }}"
                loading="eager"
                fetchpriority="high"
                sizes="(min-width: 990px) 50vw, 100vw"
              >
            {%- endif -%}
          {%- elsif section.settings.placeholder_image != blank -%}
            {{ section.settings.placeholder_image | image_url: width: 1500 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 50vw, 100vw', widths: '400, 800, 1200, 1500' }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div id="ProductInfo-{{ section.id }}" class="precision-pdp-hero__info">
      {%- if section.settings.show_stock_badge -%}
        <div class="precision-pdp-hero__badge">
          <span>
            {%- if product.selected_or_first_available_variant.available -%}
              {{ section.settings.stock_badge_text | escape }}
            {%- else -%}
              {{ section.settings.sold_out_badge_text | escape }}
            {%- endif -%}
          </span>
        </div>
      {%- endif -%}

      <div class="product__title precision-pdp-hero__title-block">
        <h1 class="product__heading h1 precision-pdp-hero__title" id="product-title-{{ section.id }}">
          {%- if section.settings.title_override != blank -%}
            {{ section.settings.title_override | escape }}
          {%- else -%}
            {{ product.title | escape }}
          {%- endif -%}
        </h1>
      </div>

      <div class="precision-pdp-hero__rating-row">
        {%- if product.metafields.reviews.rating.value != blank -%}
          {% liquid
            assign rating_decimal = 0
            assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
            if decimal >= 0.3 and decimal <= 0.7
              assign rating_decimal = 0.5
            elsif decimal > 0.7
              assign rating_decimal = 1
            endif
          %}
          <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}">
            <span aria-hidden="true" class="rating-star" style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
          </div>
          <span class="precision-pdp-hero__rating-caption">
            {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
            {%- if product.metafields.reviews.rating_count != blank -%}
          <a href="https://www.amazon.com/Tracki-Unlimited-Worldwide-Magnetic-Subscription/dp/B07N4DHFZM?ref_=ast_slp_dp&th=1" target="_blank" rel="noopener noreferrer">(42,559 positive reviews on Amazon)</a>
            {%- endif -%}
          </span>
        {%- elsif section.settings.fallback_rating_text != blank -%}
          <div class="precision-pdp-hero__rating-stars" aria-hidden="true">
            <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 0.5;">star_half</span>
          </div>
          <span class="precision-pdp-hero__rating-caption">
4.63 / 5.0 (42,559 positive reviews on Amazon)</span>
        {%- endif -%}
      </div>

      {%- assign precision_pdp_description_rendered = false -%}
      {%- assign precision_pdp_actions_open = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'buy_buttons' and precision_pdp_description_rendered == false -%}
          <div class="precision-pdp-hero__description rte">
            {%- if section.settings.description_override != blank -%}
              {{ section.settings.description_override }}
            {%- elsif product.metafields.custom.short_description != blank -%}
              <p>{{ product.metafields.custom.short_description.value | default: product.metafields.custom.short_description }}</p>
            {%- elsif product.description != blank -%}
              <p>{{ product.description | strip_html | truncate: 320 }}</p>
            {%- endif -%}
          </div>
          {%- assign precision_pdp_description_rendered = true -%}
        {%- endif -%}
        {%- case block.type -%}
          {%- when 'price' -%}
            <div class="precision-pdp-hero__price-wrap no-js-hidden" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
              {%- liquid
                assign show_badges = block.settings.show_badges
                assign price_class = 'price--' | append: block.settings.price_size
                render 'price', product: product, use_variant: true, show_badges: show_badges, price_class: price_class, sale_badge_basis: block.settings.sale_badge_basis
              -%}
            </div>
            {%- if product.quantity_price_breaks_configured? -%}
              <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                <span>{{ 'products.product.volume_pricing.note' | t }}</span>
              </div>
            {%- endif -%}
          {%- when 'variant_picker' -%}
            {% render 'product-variant-picker', block: block, product: product, product_form_id: product_form_id %}
          {%- when 'image' -%}
            {%- if block.settings.image != blank -%}
              {% liquid
                assign block_img_alt = block.settings.alt_text | default: block.settings.image.alt | default: product.title
              %}
              <div
                class="precision-pdp-hero__block-image precision-pdp-hero__block-image--{{ block.settings.image_width }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="precision-pdp-hero__block-image-link">
                {%- endif -%}
                {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', class: 'precision-pdp-hero__block-image-img', sizes: '(min-width: 990px) 50vw, 100vw', widths: '400, 600, 800, 1200, 1500', alt: block_img_alt }}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- when 'buy_buttons' -%}
            {%- unless precision_pdp_actions_open -%}
              <div class="precision-pdp-hero__actions">
              {%- assign precision_pdp_actions_open = true -%}
            {%- endunless -%}
            {% render 'buy-buttons', block: block, product: product, section_id: section.id, product_form_id: product_form_id, show_pickup_availability: true %}
        {%- endcase -%}
      {%- endfor -%}
      {%- if precision_pdp_actions_open -%}
        </div>
      {%- endif -%}
      {%- unless precision_pdp_description_rendered -%}
        <div class="precision-pdp-hero__description rte">
          {%- if section.settings.description_override != blank -%}
            {{ section.settings.description_override }}
          {%- elsif product.metafields.custom.short_description != blank -%}
            <p>{{ product.metafields.custom.short_description.value | default: product.metafields.custom.short_description }}</p>
          {%- elsif product.description != blank -%}
            <p>{{ product.description | strip_html | truncate: 320 }}</p>
          {%- endif -%}
        </div>
      {%- endunless -%}

      {%- if section.settings.trust_shipping != blank or section.settings.trust_warranty != blank -%}
        <div class="precision-pdp-hero__trust">
          {%- if section.settings.trust_shipping != blank -%}
            <div class="precision-pdp-hero__trust-item">
              <span class="material-symbols-outlined precision-pdp-icon">local_shipping</span>
              <span>{{ section.settings.trust_shipping | escape }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_warranty != blank -%}
            <div class="precision-pdp-hero__trust-item">
              <span class="material-symbols-outlined precision-pdp-icon">verified_user</span>
              <span>{{ section.settings.trust_warranty | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div
        id="precision-sticky-sentinel-{{ section.id }}"
        class="precision-pdp-sticky-sentinel"
        aria-hidden="true"
      ></div>

      {%- if section.settings.show_product_information -%}
        {% render 'precision-product-info-accordion', section: section, product: product %}
      {%- endif -%}
    </div>
  </div>

  <div
    class="precision-pdp-sticky-atc"
    id="precision-sticky-atc-{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-product-form-id="{{ product_form_id }}"
    hidden
  >
    <div class="precision-pdp-sticky-atc__inner page-width">
      <div class="precision-pdp-sticky-atc__meta">
        <p class="precision-pdp-sticky-atc__title">
          {%- if section.settings.title_override != blank -%}
            {{ section.settings.title_override | escape }}
          {%- else -%}
            {{ product.title | escape }}
          {%- endif -%}
        </p>
        
      </div>
    <button
  type="button"
  class="precision-pdp-sticky-atc__btn product-form__submit button"
  id="precision-sticky-submit-{{ section.id }}" style="
    display: flex!important;
"
>
  <span style="
    display: flex;
">{{ 'products.product.add_to_cart' | t }}</span>
  <div class="precision-pdp-sticky-atc__price" id="sticky-price-{{ section.id }}"></div>
</button>
    </div>
    {%- if product.metafields.reviews.rating.value != blank or section.settings.fallback_rating_text != blank -%}
          <div class="precision-pdp-sticky-atc__rating precision-pdp-hero__rating-row">
            {%- if product.metafields.reviews.rating.value != blank -%}
              {% liquid
                assign rating_decimal = 0
                assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                if decimal >= 0.3 and decimal <= 0.7
                  assign rating_decimal = 0.5
                elsif decimal > 0.7
                  assign rating_decimal = 1
                endif
              %}
              <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}">
                <span aria-hidden="true" class="rating-star" style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
              </div>
              <span class="precision-pdp-hero__rating-caption precision-pdp-sticky-atc__rating-caption">
                {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
                {%- if product.metafields.reviews.rating_count != blank -%}
                   (42,559 positive reviews on Amazon)
                {%- endif -%}
              </span>
            {%- elsif section.settings.fallback_rating_text != blank -%}
              <div class="precision-pdp-hero__rating-stars" aria-hidden="true">
                <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined precision-pdp-icon" style="font-variation-settings: 'FILL' 0.5;">star_half</span>
              </div>
              <span class="precision-pdp-hero__rating-caption precision-pdp-sticky-atc__rating-caption">{{ section.settings.fallback_rating_text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
  </div>

  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>

  {%- if product.media.size > 0 -%}
    {% render 'product-media-modal', product: product, variant_images: variant_images %}
  {%- endif -%}
</product-info>

{%- if product.media.size > 0 -%}
  <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: #ffffff;
    color: #000000;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {%- if product.media.size > 0 -%}
    #Slider-Gallery-{{ section.id }} {
      --force-image-ratio-percent: {{ first_image_ratio }}%;
    }
    @media screen and (max-width: 749px) {
      #Slider-Gallery-{{ section.id }} .media-mobile--adapt_first {
        padding-bottom: {{ first_image_ratio }}%;
      }
    }
    @media screen and (min-width: 750px) {
      .product--thumbnail_slider #Slider-Gallery-{{ section.id }} .media--adapt_first,
      .product--columns #Slider-Gallery-{{ section.id }} .media--adapt_first {
        padding-bottom: {{ first_image_ratio }}%;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{% schema %}
{
  "name": "Precision product hero",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "price_size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "large",
          "label": "Price size"
        },
        {
          "type": "checkbox",
          "id": "show_badges",
          "default": false,
          "label": "Show sale badges"
        },
        {
          "type": "select",
          "id": "sale_badge_basis",
          "options": [
            { "value": "disable", "label": "Disable" },
            { "value": "auto", "label": "Auto" },
            { "value": "text", "label": "Text" },
            { "value": "percentage", "label": "Percentage" },
            { "value": "value", "label": "Value" }
          ],
          "default": "auto",
          "label": "Sale badge basis"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_variant_labels",
          "default": true,
          "label": "Show variant labels"
        },
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            { "value": "dropdown", "label": "Dropdown" },
            { "value": "button", "label": "Buttons" }
          ],
          "default": "button",
          "label": "Picker type"
        },
        {
          "type": "select",
          "id": "swatch_source",
          "options": [
            { "value": "variant", "label": "Variant" },
            { "value": "file", "label": "File" },
            { "value": "native", "label": "Native" }
          ],
          "default": "variant",
          "label": "Swatch source"
        },
        {
          "type": "select",
          "id": "swatch_type",
          "options": [
            { "value": "round", "label": "Round" },
            { "value": "square", "label": "Square" },
            { "value": "none", "label": "None" }
          ],
          "default": "round",
          "label": "Swatch type"
        },
        {
          "type": "checkbox",
          "id": "enable_swatch_unavailable_click",
          "default": false,
          "label": "Enable swatch click when unavailable"
        },
        {
          "type": "page",
          "id": "size_chart",
          "label": "Size chart page"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Optional. Improves accessibility and SEO. Defaults to image alt or product title."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "select",
          "id": "image_width",
          "label": "Image width",
          "options": [
            { "value": "full", "label": "Full width" },
            { "value": "medium", "label": "Medium" },
            { "value": "small", "label": "Small" }
          ],
          "default": "full"
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_quantity_selector",
          "default": false,
          "label": "Show quantity selector"
        },
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "Show dynamic checkout (Buy now)"
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "default": false,
          "label": "Show gift card recipient"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "placeholder_image",
      "label": "Placeholder image",
      "info": "Used only if the product has no featured image."
    },
    {
      "type": "text",
      "id": "title_override",
      "label": "Product title override",
      "info": "Leave blank to use the product name from Shopify."
    },
    {
      "type": "checkbox",
      "id": "show_stock_badge",
      "default": true,
      "label": "Show availability badge"
    },
    {
      "type": "text",
      "id": "stock_badge_text",
      "default": "In Stock",
      "label": "In stock badge text"
    },
    {
      "type": "text",
      "id": "sold_out_badge_text",
      "default": "Sold out",
      "label": "Sold out badge text"
    },
    {
      "type": "text",
      "id": "reviews_label",
      "default": "reviews",
      "label": "Reviews label (after rating count)"
    },
    {
      "type": "text",
      "id": "fallback_rating_text",
      "label": "Fallback rating line",
      "info": "Shown when Shopify Reviews metafields are not set. Example: 4.2 out of 5 stars (42,821 reviews)",
      "default": "4.2 out of 5 stars (42,821 reviews)"
    },
    {
      "type": "richtext",
      "id": "description_override",
      "label": "Short description override",
      "info": "If empty, uses product metafield custom.short_description or truncated product description."
    },
    {
      "type": "text",
      "id": "trust_shipping",
      "default": "Free Shipping",
      "label": "Trust line — shipping"
    },
    {
      "type": "text",
      "id": "trust_warranty",
