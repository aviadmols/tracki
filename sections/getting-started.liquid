<section class="getting-started" id="getting-started">
  <div class="container divider-sec">
    {% if section.settings.heading != '' %}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="steps-wrapper">

      <!-- Step 1 -->
      {% for block in section.blocks %}
  <div class="step">

    {% if block.settings.count != '' %}
      <div class="step-number">{{ block.settings.count }}</div>
    {% endif %}

    <div class="step-content">

      {% if block.settings.text != '' %}
        <p class="step-text">
          {{ block.settings.text }}
        </p>
      {% endif %}

      {% if block.settings.image_icon != blank %}
        <div class="step-image">
          <img src="{{ block.settings.image_icon | img_url: 'master' }}" alt="">
        </div>
      {% endif %}

    </div>

  </div>
{% endfor %}
      {% comment %} <!-- Step 2 -->
      <div class="step">
        <div class="step-image">
          <img src="{{ 'getting-started-3_1_f66e2eb6-104f-4fc1-8baf-693153c4481e.png' | file_url }}" alt="Step 2 Illustration">
        </div>

        <div class="step-content">
          <div class="step-number">2</div>
          <div>
            <p class="step-text">
              Press and hold the power button for 3s while outside to begin GPS positioning
            </p>
            </div>
        </div>
      </div> {% endcomment %}

    </div>

  </div>
</section>

<style>
    .getting-started {
  background: #26282a;
  padding: 20px 20px;
  text-align: center;
}

.container {
  max-width: 760px;
  margin: 0 auto;
}

.section-title {
  font-size: 32px;
  font-weight: 600;
  color: #ffffff;
  {% comment %} margin-bottom: 60px; {% endcomment %}
}

.steps-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 60px;
  height: 60px;
  background: #76C773;
  color: #26282a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 20px;
}

.step-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
  max-width: 620px;
  text-align: center;
  margin: 0 auto;   /* ✅ THIS is what you're missing */
  left: 0;
  top: 0;
}

.step-text {
  font-size: 16px;
  line-height: 1.6;
  color: #d1d5db;
  margin: 0;
}
.step-subtext{
  color: var(--Text-Grey, #7E878D);
  font-size: 16px;
  font-style: normal;
  font-weight: 450;
  line-height: normal;
}
{% if page.handle != 'tracki-universal' %}
.step-image {
  background: #f3f1f0;
}
{% endif %}

.step-image {
  {% comment %} margin-top: 25px; {% endcomment %}
  padding: 30px;
  border-radius: 12px;
  width: 100%;
  display: flex;
  justify-content: center;
}

.step-image img {
  {% comment %} max-width: 420px;   /* control image size here */ {% endcomment %}
  width: 100%;
  height: auto;
}

@media (max-width: 992px) {
  .getting-started {
    padding: 80px 15px;
  }

  .section-title {
    font-size: 28px;
    margin-bottom: 50px;
  }

  .step-number {
    width: 50px;
    height: 50px;
    font-size: 20px;
    margin-bottom: 15px;
  }

  .step-text {
    font-size: 15px;
  }

  .step-subtext {
    font-size: 13px;
  }

  .step-image {
    padding: 25px;
    max-width: 100%;
  }

  .step-image img {
    max-width: 90%;
  }
}

@media (max-width: 576px) {
  .getting-started {
    padding: 60px 10px;
  }

  .section-title {
    font-size: 24px;
    margin-bottom: 40px;
  }

  .step-number {
    width: 45px;
    height: 45px;
    font-size: 18px;
    margin-bottom: 12px;
  }

  .step-text {
    font-size: 14px;
  }

  .step-subtext {
    font-size: 12px;
  }

  .step-image {
    padding: 20px;
  }

  .step-image img {
    max-width: 85%;
  }
}
</style>

{% schema %}
{
   "name":"Getting started",
   "settings":[
      {
         "type":"textarea",
         "id":"heading",
         "label":"Heading"
      }
   ],
   "blocks":[
      {
         "type":"image-with-text",
         "name":"Image With text",
         "settings":[
            {
               "type":"image_picker",
               "id":"image_icon",
               "label":"Image Icon"
            },
            {
               "type":"text",
               "id":"count",
               "label":"Count"
            },
            {
               "type":"textarea",
               "id":"text",
               "label":"Text"
            }
         ]
      }
   ],
   "presets":[
      {
         "name":"Getting started"
      }
   ]
}
{% endschema %}