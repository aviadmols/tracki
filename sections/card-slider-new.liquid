 $(document).ready(function () {

  var $carousel = $(".custom-carousel");

  function addNavIcons() {
    $('.slick-prev')
      .html('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>')
      .addClass('owl-prev');

    $('.slick-next')
      .html('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>')
      .addClass('owl-next');
  }

  function activateFirstVisible() {
    var $firstItem = $carousel
      .find('.slick-slide.slick-active')
      .first()
      .find('.item');

    if ($firstItem.length) {
      $carousel.find('.item.active').removeClass('active');
      $firstItem.addClass('active');
    }
  }

  function closePopup() {
    $carousel.removeClass("popup-open");
    $carousel.find(".item.active").removeClass("active");
  }

  function initCarousel() {

    if ($(window).width() <= 989) {

      // Destroy slick on mobile
      if ($carousel.hasClass('slick-initialized')) {
        $carousel.slick('unslick');
      }

      // 🔥 IMPORTANT: On mobile remove active from all
      closePopup();

      return;
    }

    if (!$carousel.hasClass('slick-initialized')) {

      $carousel.slick({
        slidesToShow: 3,
        slidesToScroll: 1,
        infinite: true,
        variableWidth: true,
        arrows: true,
        dots: false,
        adaptiveHeight: true,
      });

      addNavIcons();

      setTimeout(activateFirstVisible, 50);

      $carousel.on('afterChange', function () {
        closePopup();
        activateFirstVisible();
      });
    }
  }

  initCarousel();
  $(window).on('resize', initCarousel);

  /** MORE BUTTON → OPEN POPUP (WORKS ALL DEVICES) */
  $(document).on("click", ".item-more-btn", function (e) {
    e.preventDefault();
    e.stopPropagation();

    var $item = $(this).closest(".item");

    $carousel.find(".item.active").removeClass("active");
    $item.addClass("active");

    $carousel.addClass("popup-open");
  });

  /** BACK BUTTON → CLOSE POPUP */
  $(document).on("click", ".item-back-btn", function (e) {
    e.preventDefault();
    e.stopPropagation();
    closePopup();
  });

});
 

</script>




{% schema %}
{
  "name": "Card Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Tracki solutions for what matters most"
    },
    {
        "type": "select",
        "id": "title_position",
        "label": "Title Position",
        "default": "center",
        "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
        ]
    },
    {
        "type": "select",
        "id": "cart_section_layout",
        "label": "Layout",
        "default": "page-width",
        "options": [
            { "value": "page-width", "label": "Container" },
            { "value": "full-width", "label": "Full" }
        ]
    },
    {
      "type": "checkbox",
      "id": "enable_default_active",
      "label": "Enable Default Active Card",
      "default": true,
      "info": "When enabled, a card will be active by default. You can specify which card in each block's settings."
    },
    {
      "type": "checkbox",
      "id": "enable_line_title_style",
      "label": "Enable Line Title Style",
      "default": true,
      "info": "When enabled, displays decorative lines (before and after) under the section title."
    }
  ],
  "blocks": [
    {
      "type": "card_slide",
      "name": "Card Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
          "info": "Recommended size: 1200x800px or larger"
        },
        {
          "type": "checkbox",
          "id": "set_as_default_active",
          "label": "Set as Default Active Card",
          "default": false,
          "info": "Check this to make this card active by default. If multiple cards are checked, the first one will be used."
        },
        {
          "type": "image_picker",
          "id": "card_icon",
          "label": "Card Icon (optional)",
          "info": "Recommended: 60x60px transparent PNG or SVG. Leave empty to use default icon."
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Fleet and Logistics tracking"
        },
        {
          "type": "richtext",
          "id": "card_description",
          "label": "Card Description",
          "default": "<p>Tracki GPS Pro is a professional-grade tracking solution designed for businesses managing fleets, containers, packages, and high-value assets...</p>"
        },
        {
          "type": "image_picker",
          "id": "small_image_1",
          "label": "Bottom Image 1 (Left)"
        },
        {
          "type": "image_picker",
          "id": "small_image_2",
          "label": "Bottom Image 2 (Right of Left)"
        },
        {
          "type": "image_picker",
          "id": "small_image_3",
          "label": "Bottom Image 3 (Right side)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Card Carousel",
      "blocks": [
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Fleet and Logistics tracking",
            "set_as_default_active": true
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Vehicles and Cars"
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Loved ones"
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Pets"
          }
        }
      ]
    }
  ]
}
{% endschema %}