{% comment %}
  Tracki Solutions Carousel Section
  Fully converted to Shopify Liquid with customizable blocks
  Features:
  - Editable section title
  - Unlimited "Card Slide" blocks added via theme editor
  - Each card: background image, icon (optional custom SVG), title, rich text description, 3 small bottom images
  - Responsive Owl Carousel with expand/collapse functionality
  - CSS: assets\custom-styles.css  linkedin In theme.liquid
{% endcomment %}

<!-- Slick Slider CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

<!-- jQuery & Slick Slider JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  img { max-width: 100%; border: 0; }
  a { text-decoration: none; color: inherit; outline: none; transition: all 0.3s ease-in-out; }
  h2 { margin-bottom: 48px; padding-bottom: 16px; font-size: 20px; line-height: 28px; font-weight: 700; position: relative; text-transform: capitalize; }
  h3 { margin: 0 0 10px; font-size: 28px; line-height: 36px; }
  button { outline: none !important; cursor: pointer; }

  .line-title { position: relative; width: 100%; }
  {% if section.settings.enable_line_title_style %}
  .line-title::before, .line-title::after { content: ""; position: absolute; bottom: 0; left: 0; height: 4px; border-radius: 2px; }
  .line-title::before { width: 100%; background: #f2f2f2; }
  .line-title::after { width: 32px; background: #e73700; }
  {% endif %}

  .custom-carousel .item {
    transition: transform 0.35s ease;
    display: inline-block;
    position: relative;
  }

  .custom-carousel .item.active {
    z-index: 10;
  }

  .game-section .item {
    transform-origin: left center;
    transition:
      width 2.1s cubic-bezier(0.25, 0.8, 0.25, 1),
      box-shadow 2.1s ease;
  }

  /* ─── Slick Arrows Styling ─── */
  .custom-carousel .slick-prev,
  .custom-carousel .slick-next {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    display: flex !important;
    justify-content: center;
    align-items: center;
    z-index: 20;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
  }

  /* Adjust arrows closer to first and last cards */
  .custom-carousel .slick-prev { left: 10px; }  
  .custom-carousel .slick-next { right: 10px; }  

  .custom-carousel .slick-prev svg,
  .custom-carousel .slick-next svg {
    width: 20px;
    height: 20px;
    stroke: white;
  }

  .custom-carousel .slick-prev.slick-disabled,
  .custom-carousel .slick-next.slick-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .slick-slide { outline: none; } /* remove focus outline */
  .custom-carousel.popup-open .slick-arrow { pointer-events: auto; }

  /* Space between cards */
  .custom-carousel .slick-slide { margin: 0 15px; } /* 30px gap total like Owl Carousel */
</style>

<section class="game-section">
  <h2 class="line-title line-title--{{ section.settings.title_position }}">{{ section.settings.section_title }}</h2>

  <div class="custom-carousel">
    {% for block in section.blocks %}
      {% assign is_active = false %}
      {% if section.settings.enable_default_active %}
        {% if block.settings.set_as_default_active %}
          {% assign is_active = true %}
        {% elsif forloop.first and section.blocks.size > 0 %}
          {% assign has_default = false %}
          {% for b in section.blocks %}
            {% if b.settings.set_as_default_active %}
              {% assign has_default = true %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% unless has_default %}
            {% assign is_active = true %}
          {% endunless %}
        {% endif %}
      {% endif %}

      <div class="item {% if is_active %}active{% endif %}" style="background-image: url('{{ block.settings.background_image | img_url: '2048x' }}');">
        <div class="item-title">
          <div class="item-icon">
            {% if block.settings.card_icon %}
              <img src="{{ block.settings.card_icon | img_url: '60x60' }}" alt="{{ block.settings.card_title }} icon" style="width:100%; height:100%; object-fit:contain;">
            {% else %}
              <!-- SVG fallback icon -->
            {% endif %}
          </div>
          <h3>{{ block.settings.card_title }}</h3>
        </div>

        <div class="item-desc">
          {{ block.settings.card_description }}
          {% if block.settings.small_image_1 or block.settings.small_image_2 or block.settings.small_image_3 %}
            <div class="cards-inner-images">
              <div class="cards-inner-left">
                {% if block.settings.small_image_1 %}
                  <div class="image-box-container left-image-box">
                    <img src="{{ block.settings.small_image_1 | img_url: '600x' }}" alt="{{ block.settings.card_title }}">
                  </div>
                {% endif %}
                {% if block.settings.small_image_2 %}
                  <div class="image-box-container right-image-box">
                    <img src="{{ block.settings.small_image_2 | img_url: '600x' }}" alt="{{ block.settings.card_title }}">
                  </div>
                {% endif %}
              </div>
              <div class="cards-inner-right">
                {% if block.settings.small_image_3 %}
                  <div class="image-box-container">
                    <img src="{{ block.settings.small_image_3 | img_url: '600x' }}" alt="{{ block.settings.card_title }}">
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>

        <button class="item-more-btn">More...</button>
        <button class="item-back-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 23 23" fill="none">
            <g clip-path="url(#clip_back)">
              <path d="M12.9375 5.75V10.0625H17.25" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M18.6875 4.3125L12.9375 10.0625" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M5.75 12.9375H10.0625V17.25" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M4.3125 18.6875L10.0625 12.9375" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <defs><clipPath id="clip_back"><rect width="23" height="23" fill="white"/></clipPath></defs>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</section>

<script>
{% comment %} $(document).ready(function () {
  var $carousel = $(".custom-carousel");

  function addNavIcons() {
    $('.slick-prev')
      .html('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>')
      .addClass('owl-prev');

    $('.slick-next')
      .html('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>')
      .addClass('owl-next');
  }

  /** 🔑 Always open first visible card */
  function activateFirstVisible() {
    var $firstItem = $carousel
      .find('.slick-slide.slick-active')
      .first()
      .find('.item');

    if ($firstItem.length) {
      $carousel.find('.item.active').removeClass('active');
      $firstItem.addClass('active');
      $carousel.addClass('popup-open');
    }
  }

  function initCarousel() {
    if ($(window).width() <= 989) {
      if ($carousel.hasClass('slick-initialized')) {
        $carousel.slick('unslick');
      }
      return;
    }

    if (!$carousel.hasClass('slick-initialized')) {
      $carousel.slick({
        slidesToShow: 3,
        slidesToScroll: 1,
        infinite: true,
        variableWidth: true,
        arrows: true,
        dots: false,
        adaptiveHeight: true,
      });

      addNavIcons();

      /** ✅ Open first card on load */
      setTimeout(activateFirstVisible, 50);
    }
  }

  initCarousel();
  $(window).on('resize', initCarousel);

  /** 🔘 More button */
  $(".item-more-btn").on("click", function (e) {
    e.preventDefault();
    e.stopPropagation();

    $carousel.find('.item.active').removeClass('active');
    $(this).closest(".item").addClass("active");
    $carousel.addClass("popup-open");
  });

  /** 🔙 Back button → restore first card */
  $(".item-back-btn").on("click", function (e) {
    e.preventDefault();
    e.stopPropagation();
    setTimeout(activateFirstVisible, 50);
  });

  /** ⭐ KEY FIX: after arrow click or swipe */
  $carousel.on('afterChange', function () {
    activateFirstVisible();
  });
});  {% endcomment %}
