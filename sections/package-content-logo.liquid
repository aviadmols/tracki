<style>
  .image-title-grid {
    padding: 40px 20px;
    text-align: center;
    background: #f3f1f0;
    {% comment %} margin-bottom: 70px; {% endcomment %}
  }

  .image-title-grid__heading {
    font-size: 30px;
    margin-bottom: 40px;
    font-weight: 700;
    color: #26282a;
    margin-top: 0;
  }

  .image-title-grid__wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .image-title-grid__item{
    display: flex;
  flex-direction: column;
  align-items: center;
  width: 180px;
}
  .image-title-grid__item img {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-title-grid__title {
    margin-top: 15px;
    font-size: 18px;
    color: #26282a;
  }
</style>

<section class="image-title-grid" id="package-cont">
  
  {% if section.settings.heading != blank %}
    <h2 class="image-title-grid__heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="image-title-grid__wrapper">
    {% for block in section.blocks %}
      <div class="image-title-grid__item" {{ block.shopify_attributes }}>
        
        {% if block.settings.image != blank %}
          <img 
            src="{{ block.settings.image | image_url: width: 600 }}" 
            alt="{{ block.settings.title | escape }}"
          >
        {% endif %}

        {% if block.settings.title != blank %}
          <div class="image-title-grid__title">
            {{ block.settings.title }}
          </div>
        {% endif %}

      </div>
    {% endfor %}
  </div>

</section>

{% schema %}
{
  "name": "Package Content Logo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Categories"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Image Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Title"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Package Content Logo"
    }
  ]
}
{% endschema %}
