<section class="feature-section" style="background: {{ section.settings.bg_color }};" id="find-device">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="feature-section__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="feature-section__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="feature-section__blocks">
      {% for block in section.blocks %}
        <div class="feature-block" {{ block.shopify_attributes }}>

          <!-- Text content -->
          <div class="feature-block__content">
            {% if block.settings.title1 != blank %}
              <h3 class="feature-block__title1">{{ block.settings.title1 }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p class="feature-block__text">{{ block.settings.text }}</p>
            {% endif %}

            {% if block.settings.title2 != blank %}
              <h4 class="feature-block__title2">{{ block.settings.title2 }}</h4>
            {% endif %}
          </div>

          <!-- Image -->
          {% if block.settings.image != blank %}
            <div class="feature-block__image">
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.title1 }}
            </div>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.feature-section {
  color: #fff;
  {% comment %} padding: 80px 20px; {% endcomment %}
  text-align: center;
}

.feature-section__heading {
  font-size: 32px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
}

.feature-section__subheading {
  font-size: 18px;
  max-width: 700px;
  margin: 0 auto 50px;
  text-align: center;
}

/* Each Block */
.feature-section__blocks {
  display: flex;
  flex-direction: column;
  {% comment %} margin: 0 0 0; {% endcomment %}
  {% comment %} gap: 80px; {% endcomment %}
}

.feature-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20px;
}

/* Text content */
.feature-block__content {
  max-width: 700px;
}

.feature-block__title1 {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 10px;
  line-height: 1.3;
}

.feature-block__text {
  font-size: 16px;
  margin-bottom: 20px;
  line-height: 1.5;
}

.feature-block__title2 {
  font-size: 20px;
  font-weight: 700;
  color: #76C773;
  margin: 0 0 0;
  {% comment %} margin-bottom: 20px;
  padding-top: 40px; {% endcomment %}
}

/* Image */
.feature-block__image img {
  max-width: 500px;   /* reduce from 700px to 500px */
  width: 100%;
  height: auto;
  border-radius: 10px;
  display: block;
  margin: 0 auto;     /* center the image */
}

/* Tablet */
@media (max-width: 1024px) {
  .feature-block__title1 {
    font-size: 24px;
  }
  .feature-block__text {
    font-size: 15px;
  }
  .feature-block__title2 {
    font-size: 18px;
  }
}

/* Mobile */
@media (max-width: 600px) {
  .feature-section__heading {
    font-size: 24px;
    margin-bottom: 20px;
  }
  .feature-section__subheading {
    font-size: 16px;
    margin-bottom: 30px;
  }
  .feature-block__title1 {
    font-size: 22px;
  }
  .feature-block__text {
    font-size: 14px;
  }
  .feature-block__title2 {
    font-size: 16px;
  }
  .feature-block__image img {
    max-width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Find Your Device",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Features"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Learn more about our product features"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on Tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Block",
      "settings": [
        {
          "type": "text",
          "id": "title1",
          "label": "Title above Text",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Feature description goes here."
        },
        {
          "type": "text",
          "id": "title2",
          "label": "Title above Image",
          "default": "Image Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Find Your Device",
      "category": "Custom"
    }
  ]
}
{% endschema %}

