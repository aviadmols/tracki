<script>
$(document).ready(function () {

  var $carousel = $(".custom-carousel");
  var owl;

  function addNavIcons() {
    $(".custom-carousel .owl-prev").html(
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>'
    );
    $(".custom-carousel .owl-next").html(
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'
    );
  }

  function updateNavState() {
    if (!owl) return;
    // Owl already adds .disabled — we just ensure visual consistency
    $carousel.find('.owl-prev, .owl-next').each(function() {
      var $btn = $(this);
      if ($btn.hasClass('disabled')) {
        $btn.css({ opacity: 0.4, cursor: 'not-allowed' });
      } else {
        $btn.css({ opacity: 1, cursor: 'pointer' });
      }
    });
  }

  function collapseAll() {
    $carousel.find('.item.active').removeClass('active');
    $carousel.removeClass('popup-open');
    $carousel.find('.owl-nav').css('pointer-events', 'auto');
  }

  function initCarousel() {
    var width = $(window).width();
    if (width <= 989) {
      if (owl) {
        owl.trigger('destroy.owl.carousel');
        owl = null;
      }
      $carousel.removeClass('owl-carousel owl-loaded owl-theme');
      return;
    }

    if (owl) {
      owl.trigger('destroy.owl.carousel');
    }

    owl = $carousel.owlCarousel({
      autoWidth: true,
      loop: true,
      center: false,
      margin: 30,
      nav: true,
      dots: false,
      navText: ['', ''],
      slideBy: 1,
      startPosition: 0,
      mouseDrag: true,      // we'll control it dynamically
      touchDrag: true,
               // delay between scrolls (0 = continuous)
   
      onInitialized: function () {
        addNavIcons();
        updateNavState();
      },
      onTranslated: updateNavState,
      onResized: updateNavState,
      onDrag: function() {
        // Optional: collapse when user starts dragging
        collapseAll();
      }
    });
  }

  initCarousel();
  $(window).on('resize', initCarousel);

  // ────────────────────────────────────────────────
  // More / Back logic — allow nav even when expanded
  // ────────────────────────────────────────────────
  $(".item-more-btn").on("click", function (e) {
    e.preventDefault();
    e.stopPropagation();

    var $item = $(this).closest(".item");

    // Collapse others + this one if already open
    collapseAll();

    // Open this one
    $item.addClass("active");
    $carousel.addClass("popup-open");

    // Optional: disable drag while reading expanded content
    owl.options.mouseDrag = false;
    owl.options.touchDrag  = false;
    owl.refresh();   // important after option change

    // But nav still clickable
    $carousel.find('.owl-nav').css('pointer-events', 'auto');
  });

  $(".item-back-btn").on("click", function (e) {
    e.preventDefault();
    e.stopPropagation();

    collapseAll();

    // Re-enable drag
    owl.options.mouseDrag = true;
    owl.options.touchDrag  = true;
    owl.refresh();

    setTimeout(updateNavState, 40);
  });

  // When user clicks prev/next → force collapse first
  $carousel.on('click', '.owl-prev, .owl-next', function(e) {
    if ($(this).hasClass('disabled')) return;

    // Collapse expanded card before slide happens
    collapseAll();

    // Re-enable drag (in case it was off)
    owl.options.mouseDrag = true;
    owl.options.touchDrag  = true;
    owl.refresh();
  });

  // After any slide completes → make sure nav looks correct
  owl.on('translated.owl.carousel', function() {
    setTimeout(updateNavState, 40);
  });
});
</script>



{% style %}
.game-section .owl-theme .owl-nav [class*="owl-"].disabled {
  background: transparent !important;
  cursor: not-allowed;
  opacity: 0.4;
  pointer-events: none;
}

.game-section .owl-theme .owl-nav [class*="owl-"].disabled svg {
  stroke: #aaa;           /* or your disabled color */
}

.game-section .owl-nav {
  pointer-events: auto !important;   /* always clickable */
}

.game-section .owl-theme .owl-nav [class*="owl-"] {
  pointer-events: auto;
}

.game-section .owl-theme .owl-nav [class*="owl-"].disabled {
  opacity: 0.4;
  cursor: not-allowed;
  pointer-events: none !important;
}
{% endstyle %}

{% schema %}
{
  "name": "Card Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Tracki solutions for what matters most"
    },
    {
        "type": "select",
        "id": "title_position",
        "label": "Title Position",
        "default": "center",
        "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
        ]
    },
    {
        "type": "select",
        "id": "cart_section_layout",
        "label": "Layout",
        "default": "page-width",
        "options": [
            { "value": "page-width", "label": "Container" },
            { "value": "full-width", "label": "Full" }
        ]
    },
    {
      "type": "checkbox",
      "id": "enable_default_active",
      "label": "Enable Default Active Card",
      "default": true,
      "info": "When enabled, a card will be active by default. You can specify which card in each block's settings."
    },
    {
      "type": "checkbox",
      "id": "enable_line_title_style",
      "label": "Enable Line Title Style",
      "default": true,
      "info": "When enabled, displays decorative lines (before and after) under the section title."
    }
  ],
  "blocks": [
    {
      "type": "card_slide",
      "name": "Card Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
          "info": "Recommended size: 1200x800px or larger"
        },
        {
          "type": "checkbox",
          "id": "set_as_default_active",
          "label": "Set as Default Active Card",
          "default": false,
          "info": "Check this to make this card active by default. If multiple cards are checked, the first one will be used."
        },
        {
          "type": "image_picker",
          "id": "card_icon",
          "label": "Card Icon (optional)",
          "info": "Recommended: 60x60px transparent PNG or SVG. Leave empty to use default icon."
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Fleet and Logistics tracking"
        },
        {
          "type": "richtext",
          "id": "card_description",
          "label": "Card Description",
          "default": "<p>Tracki GPS Pro is a professional-grade tracking solution designed for businesses managing fleets, containers, packages, and high-value assets...</p>"
        },
        {
          "type": "image_picker",
          "id": "small_image_1",
          "label": "Bottom Image 1 (Left)"
        },
        {
          "type": "image_picker",
          "id": "small_image_2",
          "label": "Bottom Image 2 (Right of Left)"
        },
        {
          "type": "image_picker",
          "id": "small_image_3",
          "label": "Bottom Image 3 (Right side)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Card Carousel",
      "blocks": [
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Fleet and Logistics tracking",
            "set_as_default_active": true
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Vehicles and Cars"
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Loved ones"
          }
        },
        {
          "type": "card_slide",
          "settings": {
            "card_title": "Pets"
          }
        }
      ]
    }
  ]
}
{% endschema %}