<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet">
{{ 'precision-pdp-design-tokens.css' | asset_url | stylesheet_tag }}
{{ 'section-precision-product-features.css' | asset_url | stylesheet_tag }}

<div class="precision-features section-{{ section.id }}-padding">
  <div class="precision-features__inner">
    <div class="precision-features__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'feature' -%}
            <div class="precision-features__item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_name != blank -%}
                <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon_name | escape }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="precision-features__title">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="precision-features__text">{{ block.settings.text | escape }}</p>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: #f3f0ef;
    color: #000000;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Precision features",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon_name",
          "default": "satellite_alt",
          "label": "Material Symbol name",
          "info": "Icon name from Google Material Symbols (e.g. satellite_alt, battery_charging_full)."
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Feature title",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Short supporting copy for this feature.",
          "label": "Text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Precision features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "satellite_alt",
            "heading": "Global Connectivity",
            "text": "Unlimited distance tracking via 4G LTE with international roaming capability in 190+ countries."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "battery_charging_full",
            "heading": "75-Day Battery",
            "text": "Optimized power management system providing up to 75 days of active tracking on a single charge."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "shutter_speed",
            "heading": "Instant Alerts",
            "text": "Real-time geofence, movement, and speed notifications delivered directly to your smartphone."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "encrypted",
            "heading": "Secure Data",
            "text": "Military-grade encryption for all location data, ensuring your privacy is never compromised."
          }
        }
      ]
    }
  ]
}
{% endschema %}
