<script>
    document.querySelectorAll('.tracki-manual__nav a').forEach(anchor => {
anchor.addEventListener('click', function (e) {
e.preventDefault();

const target = document.querySelector(this.getAttribute('href'));
const headerOffset = 120; // adjust to your header height

if (target) {
const elementPosition = target.getBoundingClientRect().top;
const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

window.scrollTo({
top: offsetPosition,
behavior: 'smooth'
});
}
});
});

</script>
{% schema %}
{
  "name": "Tracki pro info",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "TrackiPro"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "navigation_item",
      "name": "Navigation Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link Label",
          "default": "General information"
        },
        {
          "type": "text",
          "id": "anchor",
          "label": "Anchor ID (Example: #general-info)",
          "default": "#general-info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tracki pro info",
      "blocks": [
        {
          "type": "navigation_item"
        },
        {
          "type": "navigation_item"
        }
      ]
    }
  ]
}
{% endschema %}
