<section class="contact-support-section">
  <div class="contact-support-card">

    {% if section.settings.heading != blank %}
      <h2 class="contact-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="contact-subtext">
        {{ section.settings.subtext }}
      </div>
    {% endif %}

    {% if section.settings.highlight_text != blank %}
      <div class="contact-highlight">
        {{ section.settings.highlight_text }}
      </div>
    {% endif %}

    

    <div class="contact-call-label">
      {{ section.settings.call_label }}
    </div>
    <div class="contact-divider"></div>
    <div class="contact-phone-list">
      {% for block in section.blocks %}
        <div class="contact-row">
          <div class="contact-country">
            {{ block.settings.country }}
          </div>
          <div class="contact-number">
            {{ block.settings.phone }}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="contact-button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

  </div>
</section>

<style>
.contact-support-section {
  background: #26282a;
  padding: 30px 20px 60px 20px; /* Top: 30px, Bottom: 60px */
  display: flex;
  justify-content: center;
  padding-top: 0px;
}

.contact-support-card {
  background: #111315;
  width: 380px;             /* exact box width */
  padding: 30px 35px;       /* box content */
  color: #f3f1f0;
  box-sizing: border-box;
}

.contact-title {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 8px;
  color: #f3f1f0;
  margin-top: 0px;
}

.contact-subtext {
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #8a8f95;
  margin-bottom: 4px;
}

.contact-highlight {
  color: #76C773;
  font-size: 14px;
  margin-bottom: 15px;
}

.contact-divider {
  border-bottom: 1px solid #2a2d31;
  margin-bottom: 12px;
}

.contact-call-label {
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #f3f1f0;
  margin-bottom: 8px;
}

.contact-phone-list {
  margin-bottom: 15px;
}

.contact-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}

.contact-country,
.contact-number {
  font-size: 14px;
  color: #f3f1f0;
}

.contact-button {
  display: block;
  width: 100%;
  background: #76C773;
  color: #000;
  text-align: center;
  padding: 12px 0;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s ease;
  border-radius: 2px;
}

.contact-button:hover {
  background: #76C773;
}

/* Responsive */
@media (max-width: 600px) {
  .contact-support-card {
    width: 90%;
    padding: 25px 20px;
  }

  .contact-title {
    font-size: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Contact Support Card",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact support"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Small Upper Text",
      "default": "Didn't find what you're looking for?"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Green Highlight Text",
      "default": "We're here 7-days a week to help"
    },
    {
      "type": "text",
      "id": "call_label",
      "label": "Call Label",
      "default": "Call Us"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "phone",
      "name": "Phone Number",
      "settings": [
        {
          "type": "text",
          "id": "country",
          "label": "Country Code (USA, CAN, etc)",
          "default": "USA"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+1 323 785 2020"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Support Card",
      "blocks": [
        { "type": "phone" },
        { "type": "phone" },
        { "type": "phone" }
      ]
    }
  ]
}
{% endschema %}