{%- liquid
  assign height_class = 'precision-fs-image-slider--height-natural'
  case section.settings.slide_height
    when 'viewport'
      assign height_class = 'precision-fs-image-slider--height-viewport'
    when 'ratio'
      assign height_class = 'precision-fs-image-slider--height-ratio'
  endcase

  assign ratio_class = ''
  if section.settings.slide_height == 'ratio'
    case section.settings.aspect_preset
      when '16x9'
        assign ratio_class = 'precision-fs-image-slider--ratio-16x9'
      when '4x3'
        assign ratio_class = 'precision-fs-image-slider--ratio-4x3'
      when '21x9'
        assign ratio_class = 'precision-fs-image-slider--ratio-21x9'
      when '1x1'
        assign ratio_class = 'precision-fs-image-slider--ratio-1x1'
      else
        assign ratio_class = 'precision-fs-image-slider--ratio-16x9'
    endcase
  endif
-%}

{{ 'precision-pdp-design-tokens.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'section-precision-fullscreen-image-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="precision-fs-image-slider section-{{ section.id }}-padding {{ height_class }} {{ ratio_class }}"
  id="precision-fs-slider-{{ section.id }}"
>
  {%- if section.blocks.size == 0 -%}
    <div class="page-width">
      <div class="precision-fs-image-slider__empty">
        הוסיפו בלוקי «Slide» והעלו תמונות — הסליידר יוצג מקצה לקצה ברוחב המסך.
      </div>
    </div>
  {%- else -%}
    <div class="precision-fs-image-slider__edge">
      <div class="precision-fs-image-slider__viewport">
        <ul
          id="Slider-{{ section.id }}"
          class="precision-fs-image-slider__track slider slider--mobile slider--tablet-up{% if section.settings.show_scrollbar %} -show-scroll-bar{% endif %}"
          is="scroll-snap-slider"
          data-loop="{% if section.settings.enable_loop %}true{% else %}false{% endif %}"
          data-draggable="{% if section.settings.enable_drag %}true{% else %}false{% endif %}"
          data-autoplay="{% if section.settings.autoplay %}true{% else %}false{% endif %}"
          data-autoplay-interval="{{ section.settings.autoplay_speed | times: 1000 }}"
          role="list"
        >
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'slide' -%}
                <li
                  id="Slide-{{ section.id }}-{{ forloop.index }}"
                  class="precision-fs-image-slider__slide slider__slide"
                  data-index="{{ forloop.index0 }}"
                  role="listitem"
                  {{ block.shopify_attributes }}
                >
                  {%- liquid
                    assign img = block.settings.image
                    assign img_m = block.settings.image_mobile
                    if img == blank
                      assign show_placeholder = true
                    else
                      assign show_placeholder = false
                    endif
                    assign alt = block.settings.alt | default: img.alt | default: 'Slide image'
                  -%}
                  {%- if block.settings.link != blank -%}
                    <a
                      class="precision-fs-image-slider__slide-link"
                      href="{{ block.settings.link }}"
                      aria-label="{{ alt | escape }}"
                    >
                  {%- endif -%}
                  {%- if show_placeholder -%}
                    <div class="precision-fs-image-slider__placeholder" style="background: #f0f0f0; min-height: 12rem;">
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
                    </div>
                  {%- else -%}
                    {%- assign widths = '375, 750, 1100, 1500, 2000, 3000, 3840' -%}
                    {%- assign sizes = '100vw' -%}
                    {%- if img_m != blank -%}
                      {{
                        img_m
                        | image_url: width: 3840
                        | image_tag:
                          loading: 'lazy',
                          class: 'medium-hide large-up-hide',
                          sizes: sizes,
                          widths: widths,
                          alt: alt
                      }}
                      {{
                        img
                        | image_url: width: 3840
                        | image_tag:
                          loading: 'lazy',
                          class: 'small-hide',
                          sizes: sizes,
                          widths: widths,
                          alt: alt
                      }}
                    {%- else -%}
                      {{
                        img
                        | image_url: width: 3840
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          widths: widths,
                          alt: alt
                      }}
                    {%- endif -%}
                  {%- endif -%}
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </li>
            {%- endcase -%}
          {%- endfor -%}
        </ul>

        {%- if section.blocks.size > 1 and section.settings.show_arrows -%}
          <div class="slider-buttons no-js-hidden precision-fs-image-slider__arrows">
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              {% render 'icon', icon: 'arrow' %}
            </button>
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
            >
              {% render 'icon', icon: 'arrow' %}
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "fullscreen image slider",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (mobile)",
          "info": "Optional — different crop for small screens."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "info": "Accessibility — defaults to image alt if empty."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "label": "Slide height",
      "options": [
        { "value": "natural", "label": "Natural (image height)" },
        { "value": "viewport", "label": "Tall band (viewport cover)" },
        { "value": "ratio", "label": "Fixed aspect ratio" }
      ],
      "default": "natural"
    },
    {
      "type": "select",
      "id": "aspect_preset",
      "label": "Aspect ratio",
      "options": [
        { "value": "16x9", "label": "16:9" },
        { "value": "4x3", "label": "4:3" },
        { "value": "21x9", "label": "21:9" },
        { "value": "1x1", "label": "1:1" }
      ],
      "default": "16x9",
      "visible_if": "{{ section.settings.slide_height == 'ratio' }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev / next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scrollbar",
      "label": "Show horizontal scrollbar",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Infinite loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_drag",
      "label": "Drag to scroll (mouse)",
      "default": false,
      "info": "If on, loop is disabled by the theme slider script."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "fullscreen image slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
