  <body class="{% if template == 'index' %}transparent-header{% endif %} {% unless template == 'index' %}innerpages{% endunless %} template-{{ request.page_type }}{% if request.design_mode %} shopify-design-mode{% endif %} {% if request.page_type == 'page' %}{{ page.handle }}{% endif %}{% if template.name == 'page' and template.suffix == 'parentsv2-lander' %} template-parentsv2-lander{% endif %}"
