<style>
  .accordionItem .itemText {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.accordionItem.active .switcher svg {
  transform: rotate(45deg);
  transition: transform 0.3s ease;
}

</style>