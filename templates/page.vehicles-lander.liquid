      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}

        var __variantCache = {};
        var __planMeta = {
          'plan-2yr-cta':  { title: 'Tracki Pro + 24 Month Subscription', price: '$11.54/mo + FREE device', amount: 11.54,  total: 276.90, variant: 'pro-24-month' },
          'plan-1yr-cta':  { title: 'Tracki Pro + 12 Month Subscription', price: '$16.66/mo + FREE device', amount: 16.66, total: 199.90, variant: 'pro-12-month' },
          'plan-6mo-cta':  { title: 'Tracki Pro + 6 Month Subscription',  price: '$21.65/mo + FREE device', amount: 21.65, total: 129.90,  variant: 'pro-6-month' },
          'plan-device-cta': { title: 'Tracki Pro Device Only', price: '$29.88 one-time', amount: 29.88, total: 29.88, variant: 'pro-device-only' }
        };
        function trackEvent(eventName, params) {
          var payload = Object.assign({ event: eventName }, params || {});
          try {
            var utm =
              window.TrackiAttribution && typeof window.TrackiAttribution.getMerged === 'function'
                ? window.TrackiAttribution.getMerged()
                : {};
            if (utm && Object.keys(utm).length) {
              payload.attribution = utm;
            }
          } catch (e) {}
          dataLayer.push(payload);
        }
        function selectPlan(ele) {
          var cards = document.querySelectorAll('.pricing-radio-stack .plan-card');
          for (var i = 0; i < cards.length; i++) {
            cards[i].classList.remove('selected');
            cards[i].setAttribute('aria-checked', 'false');
            cards[i].setAttribute('tabindex', '0');
          }
          ele.classList.add('selected');
          ele.setAttribute('aria-checked', 'true');
          var meta = __planMeta[ele.id];
          if (meta) {
            var t = document.getElementById('mob-bar-title');
            var p = document.getElementById('mob-bar-price');
            if (t) t.textContent = meta.title;
            if (p) p.textContent = meta.price;
            trackEvent('select_item', {
              ecommerce: {
                items: [{
                  item_name: meta.title,
                  item_variant: meta.variant,
                  price: meta.total,
                  currency: 'USD',
                  quantity: 1
                }]
              }
            });
          }
        }
        function lineItemAttributionProperties() {
          var raw = {};
          try {
            if (window.TrackiAttribution && typeof window.TrackiAttribution.getMerged === 'function') {
              raw = window.TrackiAttribution.getMerged() || {};
            }
          } catch (e) {}
          var props = {};
          Object.keys(raw).forEach(function (k) {
            var v = raw[k];
            if (v == null || String(v).trim() === '') return;
            var name = k.indexOf('_') === 0 ? k : '_' + k;
            props[name] = String(v).trim();
          });
          return props;
        }
        async function fetchVariantIdByProductId(productId) {
          if (__variantCache[productId]) return __variantCache[productId];
          var pid = String(productId);
          var page = 1;
          var maxPages = 25;
          while (page <= maxPages) {
            var r = await fetch('/products.json?limit=250&page=' + page, { credentials: 'same-origin' });
            if (!r.ok) break;
            var data = await r.json();
            if (!data.products || !data.products.length) break;
            for (var j = 0; j < data.products.length; j++) {
              var p = data.products[j];
              if (String(p.id) === pid && p.variants && p.variants.length) {
                var vid = p.variants[0].id;
                __variantCache[productId] = vid;
                return vid;
              }
            }
            if (data.products.length < 250) break;
            page++;
          }
          return null;
        }
        async function proceedToCheckout(btn) {
          var selected = document.querySelector('.pricing-radio-stack .plan-card.selected');
          if (!selected) {
            alert('Please select a plan.');
            return;
          }
          var pid = selected.getAttribute('data-product-id');
          if (!pid) {
            window.location.href = '/checkout';
            return;
          }
          var meta = __planMeta[selected.id] || {};
          var ecomItem = {
            item_name: meta.title || selected.id,
            item_variant: meta.variant || '',
            price: meta.total || 0,
            currency: 'USD',
            quantity: 1
          };

          trackEvent('add_to_cart', { ecommerce: { currency: 'USD', value: ecomItem.price, items: [ecomItem] } });

          var prevHtml = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = 'Please wait…';
          try {
            if (window.TrackiAttribution && typeof window.TrackiAttribution.syncCart === 'function') {
              await window.TrackiAttribution.syncCart();
            }
            var vid = await fetchVariantIdByProductId(pid);
            if (!vid) {
              throw new Error('Could not find product variant. Check product IDs in the theme.');
            }
            var clearRes = await fetch('/cart/clear.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              credentials: 'same-origin'
            });
            if (!clearRes.ok) throw new Error('Cart clear failed');
            var lineItem = { id: Number(vid), quantity: 1 };
            var utmProps = lineItemAttributionProperties();
            if (Object.keys(utmProps).length) {
              lineItem.properties = utmProps;
            }
            var addRes = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({ items: [lineItem] })
            });
            if (!addRes.ok) {
              var errBody = await addRes.text();
              throw new Error(errBody || 'Add to cart failed');
            }

            trackEvent('begin_checkout', { ecommerce: { currency: 'USD', value: ecomItem.price, items: [ecomItem] } });

            window.location.href = '/checkout';
          } catch (e) {
            console.error(e);
            alert('Checkout could not start. Please try again or contact support.');
            btn.disabled = false;
            btn.innerHTML = prevHtml;
          }
        }
        window.addEventListener('pageshow', function(e) {
          if (e.persisted) {
            var btns = document.querySelectorAll('.pricing-checkout-btn, #mob-bar-buy');
            for (var i = 0; i < btns.length; i++) {
              btns[i].disabled = false;
              if (btns[i].id === 'mob-bar-buy') btns[i].innerHTML = 'Buy Now →';
              else btns[i].innerHTML = 'PROCEED TO CHECKOUT';
            }
          }
        });
      </script>

