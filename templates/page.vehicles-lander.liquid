  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var ctaLinks = document.querySelectorAll('a[href="#offer"]');
    for (var i = 0; i < ctaLinks.length; i++) {
      (function(link) {
        link.addEventListener('click', function() {
          var label = (link.id || link.textContent || '').trim().substring(0, 60);
          if (typeof trackEvent === 'function') {
            trackEvent('cta_click', {
              cta_text: label,
              cta_destination: '#offer',
              cta_location: link.closest('section, nav, .mob-bar')
                ? (link.closest('section, nav, .mob-bar').id || link.closest('section, nav, .mob-bar').className.split(' ')[0])
                : 'unknown'
            });
          }
        });
      })(ctaLinks[i]);
    }

    var offerSection = document.getElementById('offer');
    if (offerSection && typeof IntersectionObserver !== 'undefined' && typeof __planMeta !== 'undefined') {
      var viewFired = false;
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && !viewFired) {
          viewFired = true;
          if (typeof trackEvent === 'function') {
            trackEvent('view_item_list', {
              ecommerce: {
                item_list_name: 'Pricing Plans — Tracki Pro Vehicle',
                items: Object.keys(__planMeta).map(function(key, idx) {
                  var m = __planMeta[key];
                  return { item_name: m.title, item_variant: m.variant, price: m.total, currency: 'USD', index: idx };
                })
              }
            });
          }
          obs.disconnect();
        }
      }, { threshold: 0.3 });
      obs.observe(offerSection);
    }
  });
  </script>
