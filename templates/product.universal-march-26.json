6 D<br\/><br\/><strong>Weight<\/strong><br\/>Earphones:<br\/>Right (Primary): 6.4 g<br\/>Left (Secondary): 6.4 g<br\/><br\/>Charging case:<br\/>55 g (without earbuds)<\/p>","page":""}},"product-details-3":{"type":"collapsible_tab","settings":{"heading":"Battery","content":"<p><strong>Battery Life<\/strong><br\/>Up to 7 hours<br\/>Up to 30 hours with charging case at moderate volume<br\/><br\/><strong>Charging Time<\/strong><br\/>Earphones: approx. 2 ½ h<br\/>Charging Case (USB-C): 2  h<br\/>Charging Case (Qi Wireless): 2 ½ h<br\/><br\/>Charging for 20 minutes gives approximately 1½ hour playback.<br\/><br\/><strong>Battery Size<\/strong><br\/>Earphones: <br\/>Right (Primary) 60 mAh<br\/>Left (Secondary) 60 mAh<br\/><br\/>Charging Case: 450 mAh<\/p>","page":""}},"60eeb066-dd65-49d7-b86e-8ef785719e6b":{"type":"collapsible_tab","settings":{"heading":"Connectivity","content":"<p><strong>Bluetooth<\/strong><br\/>Bluetooth 5.1<br\/><br\/><strong>Sound Codecs<\/strong><br\/>SBC, AAC codec, Aptx classic<br\/><br\/><strong>Microphone<\/strong><br\/>4 - With beamforming signal processing<br\/><br\/><strong>Inputs and Outputs<\/strong><br\/>1.25 m USB-A to USB-C cable for Charging<br\/>Qi Wireless Charging<\/p>","page":""}}},"block_order":["product-details-0","product-details-1","product-details-2","product-details-3","60eeb066-dd65-49d7-b86e-8ef785719e6b"],"settings":{"open_first_collapsible_row":false,"heading":"","heading_size":"h1","heading_tag":"h2","padding_top":36,"padding_bottom":16}},"164481981344fb48df":{"type":"guarantees","blocks":{"1644819813a770d5f2-0":{"type":"guarantee","settings":{"icon":"none","icon_size":"medium","custom_icon":"","title":"User Guide","title_size":"h3","text":"<p><a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0554\/5276\/2172\/files\/SAMPLE_EMPTY_USER_GUIDE.pdf?v=1646362704\" target=\"_blank\" title=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0554\/5276\/2172\/files\/SAMPLE_EMPTY_USER_GUIDE.pdf?v=1646362704\">Download<\/a><\/p>","enable_high