      <div class="features-grid">

        <!-- Card 1: SOS -->
        <div class="feature-card" data-delay="0">
          <div class="feature-card-bg" style="background-image:url({{ hero_bg }})"></div>
          <div class="feature-card-overlay" style="background:linear-gradient(135deg,rgba(180,20,20,.88),rgba(80,0,0,.94))"></div>
