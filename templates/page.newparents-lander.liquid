              <div>
                <div class="spec-label">Dimensions</div>
                <div class="spec-val">1.8" × 1.5" × 0.5"</div>
              </div>
            </div>
            <div class="spec-row">
              <div class="spec-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12l2 6h10l2-6"/><line x1="2" y1="12" x2="22" y2="12"/><circle cx="12" cy="5" r="2"/></svg></div>
              <div>
                <div class="spec-label">Weight</div>
                <div class="spec-val">1.26 oz (38g)</div>
              </div>
