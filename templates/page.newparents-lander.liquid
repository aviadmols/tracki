      <div class="compare-grid">
        <div class="compare-card compare-bad">
          <div class="compare-card-header">
            <div class="compare-icon-wrap bad"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line><line x1="4" y1="4" x2="20" y2="20"></line></svg></div>
            <div>
              <div class="compare-card-title">The Smartphone</div>
              <div class="compare-card-sub">$800–$1,200 replacement cost</div>
            </div>
          </div>
          <ul class="compare-list">
