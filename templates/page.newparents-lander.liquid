          var addRes = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ items: [lineItem] })
          });
          if (!addRes.ok) {
            var errBody = await addRes.text();
            throw new Error(errBody || 'Add to cart failed');
          }

          trackEvent('begin_checkout', { ecommerce: { currency: 'USD', value: ecomItem.price, items: [ecomItem] } });

          window.location.href = '/checkout';
        } catch (e) {
          console.error(e);
          alert('Checkout could not start. Please try again or contact support.');
          btn.disabled = false;
          btn.innerHTML = prevHtml;
        }
      };

      window.addEventListener('pageshow', function (e) {
        if (!e.persisted) return;
        var map = [
          ['np-lp-buy-btn', 'Buy Now — $14.90<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'],
          ['final-cta', 'Get Tracki Now<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'],
          ['mob-bar-buy', 'Get Tracki →']
        ];
        for (var i = 0; i < map.length; i++) {
          var el = document.getElementById(map[i][0]);
          if (el) {
            el.disabled = false;
            el.innerHTML = map[i][1];
          }
        }
      });
    })();
  </script>
  <script defer src="{{ 'newparents-lander.js' | asset_url }}"></script>

  <style>
    .header,
    .footer:not(.new),
    .mobile-dock,
    .woot--bubble-holder {
      display: none !important;
    }
  </style>
</body>
