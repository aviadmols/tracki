{"sections":{"content_scrollspy_iWw77J":{"type":"content-scrollspy","name":"t:sections.content_scrollspy.presets.name","settings":{"heading_selector":"h1.product__heading, .accordion__title, h2.title","background_color":"#272c32","text_color":"#ffffff","active_color":"#aa723e","border_color":"#aa723e","enable_animations":true,"animation_threshold":0.6,"hide_on_scroll_up":true,"show_scroll_indicator":true}},"16448066058b9355f9":{"type":"slideshow","blocks":{"bf10fce0-c41b-435a-ba73-cddba1b5be12":{"type":"image","settings":{"image_position":"center center","text_box_position":"middle-center","subheading":"<em>38-HOUR<\/em> BATTERY LIFE","subheading_size":"h5","heading":"ONE CHARGE. DAYS OF PLAY.","heading_size":"h1","heading_tag":"h2","text":"Dynasty Headphone always gives you the best sound while using active noise cancellation, for up to 38 hours of non-stop listening. That's a trip from Paris to Perth and back again.","text_size":"typeset","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"button_alt_label":"","button_alt_link":"","button_alt_size":"medium","button_alt_style_secondary":false,"enable_highlight":true,"highlight_style":"marker"}},"164480660521311b94-1":{"type":"image","settings":{"image_position":"center center","text_box_position":"middle-center","subheading":"<em>ADAPTIVE<\/em> ANC","subheading_size":"h5","heading":"PUT THE WORLD ON PAUSE","heading_size":"h1","heading_tag":"h2","text":"Five levels of noise cancellation make Dynasty Headphone our most advanced ANC headphones yet, handling everything from the hum of home life to the commotion of a commute.","text_size":"typeset","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"button_alt_label":"","button_alt_link":"","button_alt_size":"medium","button_alt_style_secondary":false,"enable_highlight":true,"highlight_style":"squiggle"}},"164480660521311b94-0":{"type":"image","settings":{"image_position":"center center","text_b