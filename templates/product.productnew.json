d-color"}},"8f0e02f8-7b30-4e8f-bcac-eed174468f4d":{"type":"text","settings":{"text":"<p>Depth, detail and delight. Dialed up beyond expectation. This is, quite simply, our finest headphone experience.<\/p>","text_size":"typeset","secondary_color":true,"enable_highlight":false,"highlight_style":"marker"}}},"block_order":["16447641709f1fda34-0","8f0e02f8-7b30-4e8f-bcac-eed174468f4d"],"disabled":true,"settings":{"text_alignment":"center","mobile_text_alignment":"left","horizontal_content":false,"narrow":false,"show_divider":false,"use_custom_colors":false,"colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#212326","colors_background":"#ffffff","colors_highlight":"#aa723e","gradient_background":"","padding_top":36,"padding_bottom":0}},"tab-collage":{"type":"tab-collage","blocks":{"tab-collage-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/bluetooth_tracker_withairtag.png","image_position":"center center","heading":"Don't be fooled by Bluetooth trackers","description":"<p>Tracki works for unlimited distance and has 100% worldwide coverage. <br\/>Don't be confused\/fooled by Bluetooth trackers like AirTag and others <br\/>who falsely claim to use GPS tracking.  They only use Bluetooth, are <br\/>only good to find your keys at home, and will work for 50 feet only.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":false,"highlight_style":"marker"}},"tab-collage-1":{"type":"image","disabled":true,"settings":{"image_position":"center center","heading":"LESS EFFORT. MORE EMOTION.","description":"<p>Quick set up, intuitive user controls and Bluetooth 5.1 allow you to connect easily to the devices you already love. And if you want to make a few sounds of your own, four microphones keep your voice crystal clear on calls.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":false,"highlight_style":"marker"}},"tab-collage-2":{"type":"image","disabled":true,"settings":{"image_position":"center center","heading":"ALMOST-<em>UNREAL<\/em> COMFORT","description":"<p>So comfortable, it's like you're not wearing them at all. Oval memory foam cushions, soft top grain lambskin and a superior fit invite you to play all day.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":true,"highlight_style":"marker"}},"tab-collage-3":{"type":"image","disabled":true,"settings":{"image_position":"center center","heading":"STANDOUR ACCESSORIES TO FIT","description":"<p>Dynasty Headphone’s finishing touches are made to be touched, with matching aluminium details and woven fabric encasing the audio cable, charging cable and flight adapter.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":false,"highlight_style":"marker"}},"28d772cd-0ee2-447d-8186-c9837111d070":{"type":"image","disabled":true,"settings":{"image_position":"center center","heading":"FIDILITY THAT FLEXES","description":"<p>For the rare moments you'll take them off, Dynasty Headphone can be folded and placed into the custom hardcase, which is lined with a super soft textile finish. No matter how much you move, they'll be safe and sound.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":false,"highlight_style":"marker"}},"4e7e819e-05a4-4e3c-82fd-aed257c54b3c":{"type":"image","disabled":true,"settings":{"image_position":"center center","heading":"MUSIC AT YOUR <em>FINGERTIPS<\/em>","description":"<p>More bass, more warmth, more you. Personalise your listening experience with the app. The equalizer and noise cancellation adjusters give you complete control over how you listen, with just a tap.<\/p>","button_label":"","button_link":"","button_size":"medium","button_style_secondary":false,"enable_highlight":true,"highlight_style":"circle"}}},"block_order":["tab-collage-0","tab-collage-1","tab-collage-2","tab-collage-3","28d772cd-0ee2-447d-8186-c9837111d070","4e7e819e-05a4-4e3c-82fd-aed257c54b3c"],"settings":{"layout":"text_first","text_box_position":"top","text_alignment":"left","image_ratio":"650px","make_collapsible_rows":false,"full_width":false,"show_divider":false,"heading":"","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","mobile_layout":"text_first","mobile_text_alignment":"left","mobile_image_ratio":"250px","colors_button_label":"#ffffff","colors_button_background":"#1a1b18","colors_text":"#ffffff","colors_border":"#d2d5d9","colors_background":"#272c31","gradient_background":"","colors_highlight":"#aa723e","padding_top":36,"padding_bottom":36,"enable_highlight":false,"highlight_style":"marker"}},"16448079723140b4d6":{"type":"collage","blocks":{"16448079726c05f8a0-0":{"type":"video","settings":{"enable_video_looping":false,"video_url":"","description":"Describe the video for customers using screen readers","heading":"","enable_highlight":false,"highlight_style":"marker"}},"cf00eccf-b810-423e-b980-c7140a8d8f03":{"type":"image","settings":{"heading":"","link":"","enable_highlight":false,"highlight_style":"marker"}},"5a6fcbbe-82e4-4199-9799-ac7dc39024a6":{"type":"image","settings":{"heading":"","link":"","enable_highlight":false,"highlight_style":"marker"}}},"block_order":["16448079726c05f8a0-0","cf00eccf-b810-423e-b980-c7140a8d8f03","5a6fcbbe-82e4-4199-9799-ac7dc39024a6"],"disabled":true,"settings":{"desktop_layout":"left","mobile_layout":"collage","apply_overlay":true,"show_divider":false,"heading":"","heading_size":"h1","heading_alignment":"left","heading_tag":"h2","colors_highlight":"#ffb503","padding_top":0,"padding_bottom":36,"enable_highlight":false,"highlight_style":"marker"}},"1644818998cec1e2a6":{"type":"testimonials","blocks":{"1644818997c04c6254-0":{"type":"testimonial","settings":{"icon":"5","text":"<p>This is a reliable product with outstanding accuracy. Also, the customer service is reachable by phone via the app, and you don’t have to wait an hour to speak with them. Very friendly, and very supportive!<\/p>","author":"Mike Jamezzz","enable_highlight":false,"highlight_style":"marker"}},"1644818997c04c6254-1":{"type":"testimonial","settings":{"icon":"5","text":"<p>I lost my device (user error, no fault of Tracki), and sent an email to them after purchasing a new device.Received a call within 24 hours, and the woman I spoke to was exceptionally helpful in transferring the subscription over to the new device, informing me of the lifetime warranty, and getting me set up so if I lose this one, it'll be replaced for free!<\/p>","author":"Jessi Coy","enable_highlight":false,"highlight_style":"marker"}},"1644818997c04c6254-2":{"type":"testimonial","settings":{"icon":"5","text":"<p>Ive had two of these trackers for a couple of years now, and they've worked really well! Recently I had noticed it kept not updating as frequently as it should've, but I attributed it to it being old. Then about a week and a half ago, one of them went missing along with the extended life battery. So I contacted their live chat customer service because I had read an article saying that Tracki will replace lost or stolen devices and accessories.<\/p>","author":"Donna Robertson","enable_highlight":false,"highlight_style":"marker"}},"1644818997c04c6254-3":{"type":"testimonial","settings":{"icon":"5","text":"<p>I really like this tracker. I use it to keep track of my special needs 7 year old who is prone to wondering.Once I opened it, selected a year subscription, and calibrated the device, I tested the device by taking my daughter for a walk around the block, having the GPS track her each minute. Several times she turned around and backtracked before returning to our original path. I was amazed at how the Tracki caught each of these movements. I haven't had to use the device to find her yet (luckily!), but am confident it will do the job if needed.<\/p>","author":"Momof5","enable_highlight":false,"highlight_style":"marker"}},"1644818997c04c6254-4":{"type":"testimonial","settings":{"icon":"5","text":"<p>Product was perfect for travel. Placed in my suitcase that I checked at the airport. It stayed charged and I was a le to track all the way to Europe and back. Also, customer service is excellent if you have questions.<\/p>","author":"Sharisse","enable_highlight":false,"highlight_style":"marker"}}},"block_order":["1644818997c04c6254-0","1644818997c04c6254-1","1644818997c04c6254-2","1644818997c04c6254-3","1644818997c04c6254-4"],"settings":{"autorotate":true,"autorotate_speed":5,"hide_images":false,"show_divider":false,"heading":"REVIEWS FROM <em>THE EXPERTS<\/em>","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","colors_highlight":"#aa723e","padding_top":36,"padding_bottom":36,"enable_highlight":true,"highlight_style":"solid-color"}},"logo_list_C8WQR6":{"type":"logo-list","blocks":{"logo_4pFqyF":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-1.png","link":""}},"logo_HVU9Ub":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-2.png","link":""}},"logo_WqxKFa":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-3.png","link":""}},"logo_c6hmBh":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-4.png","link":""}},"logo_PEMVwk":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-5.png","link":""}},"logo_fg4w9e":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/tp-features-6.png","link":""}}},"block_order":["logo_4pFqyF","logo_HVU9Ub","logo_WqxKFa","logo_c6hmBh","logo_PEMVwk","logo_fg4w9e"],"name":"t:sections.logo-list.presets.name","settings":{"opacity":72,"show_divider":false,"heading":"","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","colors_highlight":"#ffb503","padding_top":36,"padding_bottom":36,"enable_highlight":false,"highlight_style":"marker"}},"1644745953392511db":{"ty